<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <!-- COLLAPSED STATE: Floating Bubble (Chat Head) -->
    <LinearLayout
        android:id="@+id/bubble_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="visible">

        <!-- Draggable Circular Bubble with TP×MD text -->
        <RelativeLayout
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:background="@drawable/floating_bubble_bg"
            android:gravity="center"
            android:elevation="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TP×MD"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:typeface="monospace"
                android:layout_centerInParent="true" />
        </RelativeLayout>
    </LinearLayout>

    <!-- EXPANDED STATE: Lag Control Panel -->
    <LinearLayout
        android:id="@+id/panel_layout"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/panel_bg"
        android:padding="16dp"
        android:elevation="8dp"
        android:visibility="gone">

        <!-- Panel Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAG CONTROL"
                android:textColor="#00E5FF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:typeface="monospace"
                android:layout_centerVertical="true" />

            <!-- Control Actions: Collapse & Close -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true">

                <!-- Collapse / Minimize Button -->
                <TextView
                    android:id="@+id/btnMinimize"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="─"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="@drawable/circle_icon_button_bg"
                    android:layout_marginRight="8dp" />

                <!-- Close / Stop Service Button -->
                <TextView
                    android:id="@+id/btnClose"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="✕"
                    android:textColor="#FF3D00"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@drawable/circle_icon_button_bg" />
            </LinearLayout>
        </RelativeLayout>

        <!-- 7 Input Passcode Slots Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView android:id="@+id/slot0" style="@style/PasscodeSlotStyle" />
            <TextView android:id="@+id/slot1" style="@style/PasscodeSlotStyle" />
            <TextView android:id="@+id/slot2" style="@style/PasscodeSlotStyle" />
            <TextView android:id="@+id/slot3" style="@style/PasscodeSlotStyle" />
            <TextView android:id="@+id/slot4" style="@style/PasscodeSlotStyle" />
            <TextView android:id="@+id/slot5" style="@style/PasscodeSlotStyle" />
            <TextView android:id="@+id/slot6" style="@style/PasscodeSlotStyle" />
        </LinearLayout>

        <!-- Custom Numeric Keyboard Pad Grid (Table-like layout using LinearLayouts) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="14dp">

            <!-- Row 1: 1 2 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button android:id="@+id/key1" android:text="1" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/key2" android:text="2" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/key3" android:text="3" style="@style/KeypadButtonStyle" />
            </LinearLayout>

            <!-- Row 2: 4 5 6 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">
                <Button android:id="@+id/key4" android:text="4" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/key5" android:text="5" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/key6" android:text="6" style="@style/KeypadButtonStyle" />
            </LinearLayout>

            <!-- Row 3: 7 8 9 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">
                <Button android:id="@+id/key7" android:text="7" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/key8" android:text="8" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/key9" android:text="9" style="@style/KeypadButtonStyle" />
            </LinearLayout>

            <!-- Row 4: C 0 DEL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">
                <Button android:id="@+id/keyC" android:text="C" style="@style/KeypadButtonStyle" android:textColor="#FF3D00" />
                <Button android:id="@+id/key0" android:text="0" style="@style/KeypadButtonStyle" />
                <Button android:id="@+id/keyDel" android:text="DEL" style="@style/KeypadButtonStyle" android:textColor="#00E5FF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="OK"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/button_cyan_bg"
            android:layout_marginBottom="8dp" />

        <!-- Status Result Message Panel -->
        <TextView
            android:id="@+id/txtHttpStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#00E5FF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:typeface="monospace"
            android:gravity="center"
            android:visibility="gone" />

    </LinearLayout>
</FrameLayout>
