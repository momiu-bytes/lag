<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#202124">

    <!-- Screen 1: Permission Request Layout -->
    <LinearLayout
        android:id="@+id/layoutPermission"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <!-- Warning Icon Container -->
        <RelativeLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/circle_warning_bg"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="!"
                android:textColor="#00E5FF"
                android:textSize="40sp"
                android:textStyle="bold"
                android:typeface="monospace" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YÊU CẦU QUYỀN NỔI"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:typeface="monospace"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Để hiển thị nút nổi TP×MD trên màn hình khi chơi game, vui lòng cấp quyền vẽ lên ứng dụng khác cho hệ thống."
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="32dp" />

        <Button
            android:id="@+id/btnGrantPermission"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="CẤP QUYỀN TRUY CẬP (OVERLAY)"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:typeface="monospace"
            android:background="@drawable/button_cyan_bg" />

        <TextView
            android:id="@+id/txtBackToLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng xuất / Quay lại"
            android:textColor="#808080"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:padding="8dp" />
    </LinearLayout>

    <!-- Screen 2: Dashboard Control Layout -->
    <LinearLayout
        android:id="@+id/layoutDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="visible">

        <!-- Top Header Action Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LAG TP×MDUC"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:typeface="monospace"
                android:layout_centerVertical="true" />

            <!-- Logout ImageButton -->
            <ImageView
                android:id="@+id/imgLogout"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_logout_cyan"
                android:scaleType="centerInside"
                android:contentDescription="Đăng xuất" />
        </RelativeLayout>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg_with_border"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <RelativeLayout
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/circle_logo_bg_small"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TP"
                    android:textColor="#00E5FF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginLeft="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trạng thái hệ thống"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtServiceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dịch vụ nút nổi chưa kích hoạt."
                    android:textColor="#CCCCCC"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Floating Button Toggle Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/card_bg"
            android:gravity="center_vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRẠNG THÁI NÚT NỔI"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:typeface="monospace" />

                <TextView
                    android:id="@+id/txtToggleStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang tạm dừng"
                    android:textColor="#808080"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Switch to toggle overlay -->
            <Switch
                android:id="@+id/switchOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:theme="@style/CustomSwitchTheme" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Footer Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phiên bản 1.0 • Phát triển bởi Minh Đức"
            android:textColor="#808080"
            android:textSize="11sp"
            android:typeface="monospace"
            android:gravity="center"
            android:layout_marginBottom="8dp" />
    </LinearLayout>
</FrameLayout>
